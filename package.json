{
  "name": "bitbattles-backend",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "BitBattles backend — Express + DynamoDB. Serves quick_commerce (mobile) and ADMIN_PANEL.",
  "scripts": {
    "dev": "node scripts/dev.mjs",
    "dev:api": "node --watch src/server.js",
    "start": "node src/server.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:create-tables": "node scripts/create-tables.js",
    "db:delete-tables": "node scripts/create-tables.js --delete",
    "db:create-admin": "node scripts/create-admin.js"
  },
  "dependencies": {
    "@aws-sdk/client-dynamodb": "^3.658.1",
    "@aws-sdk/lib-dynamodb": "^3.1062.0",
    "bcryptjs": "^3.0.3",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.21.1",
    "jsonwebtoken": "^9.0.3",
    "pino": "^9.5.0",
    "pino-http": "^10.3.0",
    "ulid": "^3.0.2",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "supertest": "^7.0.0",
    "vitest": "^4.1.8"
  }
}
